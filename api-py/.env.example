# Local dev defaults — copy to .env and edit.

DJANGO_SECRET_KEY=dev-secret-key-change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave DATABASE_URL blank to use local SQLite (db.sqlite3).
# In production set to a Postgres URL:
#   DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=

# Required for the enrichment + outreach services (Commit 3+).
# Leave blank during local dev if you only need CRUD.
ANTHROPIC_API_KEY=
ENRICHMENT_MODEL=claude-sonnet-4-6

# CORS — comma-separated origins allowed to call the API.
# In dev the React app runs at http://localhost:5173.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Cron job tuning (used by the morning-cron management command in Commit 4)
MORNING_CRON_REENRICH=5
MORNING_CRON_SOURCE=5
MORNING_CRON_ENRICH_NEW=true
