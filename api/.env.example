DATABASE_URL="postgresql://crm:crm_dev@localhost:5432/crm_dev?schema=public"
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Optional — required only for the enrichment service (Step 4+).
# Get a key at https://console.anthropic.com. The server boots without it,
# but /accounts/:id/enrich and /enrichment/source return 503 until set.
ANTHROPIC_API_KEY=

# Optional — model used for enrichment. Defaults to claude-sonnet-4-6.
ENRICHMENT_MODEL=claude-sonnet-4-6
